# FareHarbor Lighthouse API — Read-only credentials
# Obtém em: FareHarbor Dashboard > Settings > API > Lighthouse API
# NUNCA commitar o .env com valores reais. Adicionar .env ao .gitignore.

FAREHARBOR_APP_KEY=your_app_key_here
FAREHARBOR_USER_KEY=your_user_key_here

# CORS — domínio do website em produção
# Em desenvolvimento pode ficar vazio (permite *)
ALLOWED_ORIGIN=https://viamar-berlenga.com
